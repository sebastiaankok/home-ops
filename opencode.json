{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "argocd": {
      "type": "local",
      "command": ["npx", "-y", "argocd-mcp", "stdio"],
      "enabled": true,
      "environment": {
        "ARGOCD_BASE_URL": "https://argocd.otohgunga.nl/",
        "ARGOCD_API_TOKEN": "{env:ARGOCD_TOKEN}"
      }
    }
  }
}
